# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Encryption (AES-256-GCM) — must be exactly 64 hex chars (32 bytes)
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# Server
PORT=4000
NODE_ENV=development

# Geocoding (OpenStreetMap Nominatim — free, no key required)
GEOCODING_USER_AGENT=icloud-backup-app/1.0 myvendoraistripe@gmail.com

# Polling interval in milliseconds (default 3 minutes)
POLL_INTERVAL_MS=180000

# Admin panel — set a strong secret, visit http://localhost:4000/admin
ADMIN_SECRET=change_this_to_a_strong_password
